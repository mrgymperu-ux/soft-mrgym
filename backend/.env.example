# Copiar este archivo a ".env" y completar los valores reales.
# El archivo .env NO debe subirse a git (agregar a .gitignore).

# Conexion a base de datos.
# Si se omite, el sistema usa SQLite local (sql_app.db) automaticamente,
# util para desarrollo sin configurar nada.
# Para produccion con Postgres (Supabase/Neon), usar algo asi:
# DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db
DATABASE_URL=

# Clave secreta para firmar los tokens JWT. OBLIGATORIO definir una
# propia y unica antes de desplegar a produccion real. Se puede
# generar una rapido en Python con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Credenciales del usuario administrador inicial, creado solo la
# primera vez que se ejecuta init_db.py (si ya existe algun usuario,
# no se crea de nuevo). Cambiar estos valores antes de producir.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
ADMIN_NOMBRE=Administrador
