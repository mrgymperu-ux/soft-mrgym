# ============================================================
# Variables de entorno para producción
# ============================================================
# La BD vive en Supabase (gratis permanente).
# El web service corre en Render (gratis).

# Base de datos PostgreSQL — Supabase connection string
# Obtenerla en: supabase.com → Settings → Database → Connection string → URI
# IMPORTANTE: usar puerto 5432 (no 6543) y agregar ?sslmode=require
# DATABASE_URL=postgresql://postgres.[ref]:PASSWORD@aws-0-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# Clave secreta para firmar JWT (Render la genera automáticamente)
# SECRET_KEY=una-clave-super-secreta-de-al-menos-32-caracteres

# Orígenes permitidos para CORS (separados por coma, o * para todos)
# CORS_ORIGINS=https://soft-mrgym.onrender.com
